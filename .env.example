# RetrievAI — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

# ── Google AI Studio ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier includes Gemini 1.5 Flash + text-embedding-004
GOOGLE_API_KEY=your_google_api_key_here

# ── Qdrant Cloud ─────────────────────────────────────────────
# Sign up at: https://cloud.qdrant.io (free tier, no credit card)
# After creating a cluster, copy the cluster URL from the dashboard
QDRANT_URL=https://your-cluster-id.region.provider.cloud.qdrant.io
# Create an API key in Qdrant Cloud → your cluster → API Keys tab
QDRANT_API_KEY=your_qdrant_api_key_here
